{
  "expo": {
    "name": "Taguig NutriApp",
    "slug": "Taguig-NutriApp",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/FixedSquareNoBg.png",
    "scheme": "taguig-nutriapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "Allow this app to read your health data.",
        "NSHealthUpdateUsageDescription": "Allow this app to write health data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/FixedSquareNoBg.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.joelgamba.TaguigNutriApp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/FixedSquareNoBg.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/without_bg_think_big_2k_px.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 26
          }
        }
      ],
      "expo-health-connect",
      [
        "react-native-health",
        {
          "healthSharePermission": "Allow this app to read your health data.",
          "healthUpdatePermission": "Allow this app to write health data.",
          "isClinicalDataEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "005f41e5-06ed-4646-addf-f068457abd0a"
      }
    },
    "owner": "joelgamba",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": false
    }
  }
}
